{
  "name": "ledgerflow-credit-tracker",
  "version": "1.0.0",
  "description": "LedgerFlow - Customer Dues & Credit Bookkeeping Tracker",
  "scripts": {
    "install:all": "npm install && npm install --prefix frontend",
    "dev:backend": "node frontend/api/server.js",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev": "concurrently --kill-others \"npm run dev:backend\" \"npm run dev:frontend\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "supabase": "^2.109.0"
  }
}
